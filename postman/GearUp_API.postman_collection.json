            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Cycling\",\n  \"description\": \"Bikes and cycling gear\"\n}"
            },
            "url": "{{baseUrl}}/api/admin/categories"
          }
        },
        {
          "name": "Update Category",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
