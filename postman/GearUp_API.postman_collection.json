              "raw": "{\n  \"name\": \"Cycling\",\n  \"description\": \"Updated cycling category\"\n}"
            },
            "url": "{{baseUrl}}/api/admin/categories/{{categoryId}}"
          }
        },
        {
          "name": "Get All Users",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (Array.isArray(res?.data) && res.data.length) {",
                  "  const user = res.data.find(u => u.role !== 'ADMIN') || res.data[0];",
                  "  if (user?.id) pm.collectionVariables.set('userId', user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/admin/users"
          }
        },
