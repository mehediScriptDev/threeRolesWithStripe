    {
      "name": "2. Public",
      "item": [
        {
          "name": "Get Categories",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/categories"
          }
        },
        {
          "name": "Get All Gear",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/gear?available=true",
              "host": ["{{baseUrl}}"],
              "path": ["api", "gear"],
              "query": [
                { "key": "available", "value": "true" },
                { "key": "brand", "value": "Giant", "disabled": true },
                { "key": "category", "value": "{{categoryId}}", "disabled": true },
                { "key": "minPrice", "value": "10", "disabled": true },
                { "key": "maxPrice", "value": "100", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Gear By ID",
          "request": {
            "method": "GET",
            "header": [],
