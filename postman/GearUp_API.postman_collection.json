{
  "info": {
    "_postman_id": "gearup-api-collection-001",
    "name": "GearUp API",
    "description": "GearUp — Sports & Outdoor Gear Rental API\n\nLive API: https://gearup-api-kbz0.onrender.com\n\nRoles: CUSTOMER | PROVIDER | ADMIN\n\nSuggested order:\n1) Admin login → create category\n2) Provider register/login → add gear\n3) Customer register/login → create rental\n4) Provider confirms order\n5) Customer creates/confirms payment\n6) Provider PICKED_UP → RETURNED\n7) Customer review\n\nAdmin seed:\nemail: admin@gearup.com\npassword: admin123\n\nNote: Free Render may sleep; first request can take 30–60s.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://gearup-api-kbz0.onrender.com" },
    { "key": "adminToken", "value": "" },
    { "key": "providerToken", "value": "" },
    { "key": "customerToken", "value": "" },
    { "key": "categoryId", "value": "" },
    { "key": "gearId", "value": "" },
    { "key": "rentalId", "value": "" },
    { "key": "paymentId", "value": "" },
    { "key": "userId", "value": "" }
  ],
