            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Register Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res?.data?.token) {",
                  "  pm.collectionVariables.set('customerToken', res.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ali Customer\",\n  \"email\": \"ali@mail.com\",\n  \"password\": \"123456\",\n  \"role\": \"CUSTOMER\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
